# .streamlit/secrets.toml
# Copy this file content into the Streamlit Cloud "Secrets" dashboard
# Do NOT commit this file — it's in .gitignore

# ── Angel One SmartAPI ─────────────────────────────────────────────────────
ANGEL_API_KEY = "your_angel_one_api_key_here"
ANGEL_CLIENT_ID = "your_client_id_here"
ANGEL_PASSWORD = "your_trading_password_here"
ANGEL_TOTP_SECRET = "your_totp_secret_here"

# ── Database (Supabase / Railway / Neon free tier recommended) ─────────────
DATABASE_URL = "postgresql://user:password@host:5432/protrader"

# ── Anthropic Claude AI (for Journal & Sentiment, Blocks 22, 29) ──────────
ANTHROPIC_API_KEY = "sk-ant-your_key_here"

# ── Email SMTP (Gmail App Password) ───────────────────────────────────────
SMTP_EMAIL = "yourtrading@gmail.com"
SMTP_PASSWORD = "your_16_char_gmail_app_password"

# ── WhatsApp Business Cloud API (Block 34) ────────────────────────────────
WHATSAPP_TOKEN = "your_whatsapp_cloud_api_token"
WHATSAPP_PHONE_ID = "your_phone_number_id"

# ── App Security ──────────────────────────────────────────────────────────
APP_SECRET_KEY = "generate_a_random_64_char_string_here"
ADMIN_PIN = "123456"
